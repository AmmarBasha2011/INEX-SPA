if ($command === "clear:routes") {
    // The global $isNewRoutingSystemActive is set at the beginning of the script.

    if ($isNewRoutingSystemActive) {
        echo "Operating in NEW routing system mode.\n";

        $confirm_clear_routes_file = strtolower(readline("Do you want to clear the routes.php file (reset to empty \$routes array)? (yes/no): "));
        if ($confirm_clear_routes_file === 'yes') {
            $routes_file_path = __DIR__ . '/routes.php';
            $original_content = file_exists($routes_file_path) ? file_get_contents($routes_file_path) : "<?php\n\n\$routes = [];\n";

            $routes_declaration_pos = strpos($original_content, '$routes =');
            $header_content = '';

            if ($routes_declaration_pos !== false) {
                // Try to preserve content before '$routes ='
                $header_content = substr($original_content, 0, $routes_declaration_pos);
                // Ensure header has PHP opening tag if it's not just whitespace
                if (trim($header_content) === '' && strpos($original_content, '<?php') === 0) {
                    $header_content = "<?php\n\n"; // Default minimal header
                } elseif (strpos(trim($header_content), '<?php') === false) {
                     // If <?php is missing from header (e.g. it was just comments), add it.
                    $header_content = "<?php\n" . $header_content;
                }
            } else {
                // Fallback: if '$routes =' not found, use a default header.
                // This might happen if routes.php was completely emptied or malformed.
                $header_content = "<?php\n\n/**\n * Web Routes (New System)\n * Cleared by Ammar CLI\n */\n\n";
            }

            // Ensure there's a new line after header if it's not empty
            if(trim($header_content) !== '' && substr($header_content, -1) !== "\n") {
                $header_content .= "\n";
            }

            $cleared_routes_content = $header_content . "\$routes = [];\n";

            if (file_put_contents($routes_file_path, $cleared_routes_content) !== false) {
                echo "routes.php has been cleared (reinitialized to \$routes = []).\n";
            } else {
                echo "Error clearing routes.php!\n";
            }
        }

        $confirm_clear_web_files = strtolower(readline("Do you also want to delete all *.ahmed.php files from the web/ directory and its subdirectories? (yes/no): "));
        if ($confirm_clear_web_files === 'yes') {
            echo "Deleting *.ahmed.php files from web/ directory...\n";
            $deleted_count = 0;
            $web_files = new RecursiveIteratorIterator(
                new RecursiveDirectoryIterator(WEB_FOLDER, RecursiveDirectoryIterator::SKIP_DOTS),
                RecursiveIteratorIterator::CHILD_FIRST
            );

            foreach ($web_files as $fileinfo) {
                if ($fileinfo->isFile() && $fileinfo->getExtension() === 'ahmed.php') {
                    if (unlink($fileinfo->getRealPath())) {
                        echo "  Deleted: " . $fileinfo->getRealPath() . "\n";
                        $deleted_count++;
                    } else {
                        echo "  Failed to delete: " . $fileinfo->getRealPath() . "\n";
                    }
                }
            }
            echo $deleted_count . " *.ahmed.php file(s) deleted from web/ directory.\n";
        }

    } else {
        // --- Legacy Routing System Logic ---
        echo "Operating in LEGACY routing system mode.\n";
        $confirm_clear_web_files_legacy = strtolower(readline("Are you sure you want to delete all *.ahmed.php files from the web/ directory and its subdirectories? (yes/no): "));
        if ($confirm_clear_web_files_legacy === 'yes') {
            echo "Deleting *.ahmed.php files from web/ directory...\n";
            $deleted_count = 0;
            // Use RecursiveIteratorIterator to find all .ahmed.php files in web/ and subdirectories
            $web_files = new RecursiveIteratorIterator(
                new RecursiveDirectoryIterator(WEB_FOLDER, RecursiveDirectoryIterator::SKIP_DOTS),
                RecursiveIteratorIterator::CHILD_FIRST // Important for deleting files before directories if we were deleting dirs
            );

            foreach ($web_files as $fileinfo) {
                if ($fileinfo->isFile() && $fileinfo->getExtension() === 'ahmed.php') {
                    if (unlink($fileinfo->getRealPath())) {
                        echo "  Deleted: " . $fileinfo->getRealPath() . "\n";
                        $deleted_count++;
                    } else {
                        echo "  Failed to delete: " . $fileinfo->getRealPath() . "\n";
                    }
                }
            }
            echo $deleted_count . " *.ahmed.php file(s) deleted from web/ directory.\n";

        } else {
            echo "Operation cancelled by user.\n";
        }
    }
    exit(0);
}

